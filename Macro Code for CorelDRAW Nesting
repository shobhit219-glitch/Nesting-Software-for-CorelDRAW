' ============================================================================
' ShoeNester v8.0 - WORKING True-Shape Nesting for CorelDRAW 2025
' ============================================================================
'
' FIX: Removed IsOnShape (doesn't work reliably in CDR2025).
' Now uses curve-node polygon scanline fill for rasterization.
'
' HOW IT WORKS:
'   1. Paste shape, read its curve nodes (actual outline points)
'   2. Convert nodes to pixel coordinates relative to shape origin
'   3. Scanline-fill the polygon onto a pixel bitmap
'   4. Use that bitmap for collision-free placement on the master grid
'   5. Shapes interlock into each other's concavities
'
' INSTALLATION:
'   Alt+Shift+F11 > GlobalMacros > NestingEngine
'   Delete old code, paste this, Ctrl+S, Alt+F8 > Run
'
' ============================================================================

Option Explicit

Private Const CELL As Double = 3  ' Pixel size in mm

Private m_SheetW As Double
Private m_SheetH As Double
Private m_Gap As Double
Private m_Copies As Long
Private m_DoRotate As Boolean
Private m_Margin As Double
Private m_UsableW As Double
Private m_UsableH As Double

Private m_GW As Long
Private m_GH As Long
Private m_Grid() As Boolean
Private m_RowFull() As Boolean


' ============================================================================
' MAIN
' ============================================================================
Public Sub RunShoeNester()
    On Error GoTo ErrHandler
    
    If Documents.Count = 0 Then
        MsgBox "Open a document with shoe components first!", vbExclamation, "ShoeNester"
        Exit Sub
    End If
    
    Dim srcDoc As Document
    Set srcDoc = ActiveDocument
    
    Dim sr As ShapeRange
    If ActiveSelection.Shapes.Count > 0 Then
        Set sr = ActiveSelection.Shapes.All
    Else
        Set sr = ActivePage.Shapes.All
    End If
    
    If sr.Count = 0 Then
        MsgBox "No shapes found!", vbExclamation, "ShoeNester"
        Exit Sub
    End If
    
    Dim msg As String
    msg = "ShoeNester v8.0 - True-Shape Nesting" & vbCrLf
    msg = msg & "Found: " & sr.Count & " component(s)" & vbCrLf & vbCrLf
    msg = msg & "Click OK to configure."
    If MsgBox(msg, vbOKCancel + vbInformation, "ShoeNester") = vbCancel Then Exit Sub
    
    Dim ps As String
    ps = InputBox("Sheet: 1=A4 2=A3 3=A2 4=A1 5=A0 6=Letter 7=24x36 8=Custom", "ShoeNester", "3")
    If ps = "" Then Exit Sub
    Select Case Val(ps)
        Case 1: m_SheetW = 210: m_SheetH = 297
        Case 2: m_SheetW = 297: m_SheetH = 420
        Case 3: m_SheetW = 420: m_SheetH = 594
        Case 4: m_SheetW = 594: m_SheetH = 841
        Case 5: m_SheetW = 841: m_SheetH = 1189
        Case 6: m_SheetW = 216: m_SheetH = 279
        Case 7: m_SheetW = 610: m_SheetH = 914
        Case 8
            Dim wS As String
            Dim hS As String
            wS = InputBox("Width (mm):", "ShoeNester", "600")
            If wS = "" Then Exit Sub
            hS = InputBox("Height (mm):", "ShoeNester", "900")
            If hS = "" Then Exit Sub
            m_SheetW = Val(wS): m_SheetH = Val(hS)
        Case Else: m_SheetW = 420: m_SheetH = 594
    End Select
    
    Dim sg As String
    sg = InputBox("Gap (mm):", "ShoeNester", "3")
    If sg = "" Then Exit Sub
    m_Gap = Val(sg)
    
    Dim scp As String
    scp = InputBox("Copies per component:", "ShoeNester", "1")
    If scp = "" Then Exit Sub
    m_Copies = CLng(Val(scp))
    If m_Copies < 1 Then m_Copies = 1
    
    m_DoRotate = (MsgBox("Allow rotation?", vbYesNo, "ShoeNester") = vbYes)
    
    Dim sm As String
    sm = InputBox("Margin (mm):", "ShoeNester", "5")
    If sm = "" Then Exit Sub
    m_Margin = Val(sm)
    
    m_UsableW = m_SheetW - m_Margin * 2
    m_UsableH = m_SheetH - m_Margin * 2
    If m_UsableW <= 0 Or m_UsableH <= 0 Then
        MsgBox "Margins too large!", vbExclamation, "ShoeNester"
        Exit Sub
    End If
    
    Dim totalItems As Long
    totalItems = sr.Count * m_Copies
    
    msg = "Pieces: " & totalItems & " | Sheet: " & m_SheetW & "x" & m_SheetH & "mm | Proceed?"
    If MsgBox(msg, vbOKCancel, "ShoeNester") = vbCancel Then Exit Sub
    
    Application.Optimization = True
    
    ' Sort largest first
    Dim itemSrc() As Long
    Dim itemAr() As Double
    ReDim itemSrc(1 To totalItems)
    ReDim itemAr(1 To totalItems)
    Dim idx As Long
    Dim i As Long
    Dim c As Long
    idx = 0
    For i = 1 To sr.Count
        Dim ar As Double
        ar = sr(i).SizeWidth * sr(i).SizeHeight
        For c = 1 To m_Copies
            idx = idx + 1
            itemSrc(idx) = i
            itemAr(idx) = ar
        Next c
    Next i
    
    Dim swp As Boolean
    Dim td As Double
    Dim tl As Long
    Do
        swp = False
        For i = 1 To totalItems - 1
            If itemAr(i) < itemAr(i + 1) Then
                td = itemAr(i): itemAr(i) = itemAr(i + 1): itemAr(i + 1) = td
                tl = itemSrc(i): itemSrc(i) = itemSrc(i + 1): itemSrc(i + 1) = tl
                swp = True
            End If
        Next i
    Loop While swp
    
    ' Create dest doc
    Dim destDoc As Document
    Set destDoc = CreateDocument
    destDoc.Unit = cdrMillimeter
    Dim pg As Page
    Set pg = destDoc.Pages(1)
    pg.SetSize m_SheetW, m_SheetH
    Call InitGrid
    Call DrawBox(pg)
    
    Dim pgCnt As Long
    pgCnt = 1
    Dim plCnt As Long
    plCnt = 0
    
    For i = 1 To totalItems
        Application.StatusBar = "ShoeNester: " & i & "/" & totalItems & " (Pg " & pgCnt & ")"
        DoEvents
        
        Dim ok As Boolean
        ok = PlaceItem(srcDoc, sr, itemSrc(i), destDoc, pg)
        
        If Not ok Then
            Set pg = destDoc.AddPages(1)
            pg.SetSize m_SheetW, m_SheetH
            pgCnt = pgCnt + 1
            Call InitGrid
            Call DrawBox(pg)
            ok = PlaceItem(srcDoc, sr, itemSrc(i), destDoc, pg)
        End If
        
        If ok Then plCnt = plCnt + 1
    Next i
    
    Application.Optimization = False
    Application.StatusBar = ""
    destDoc.Activate
    destDoc.Pages(1).Activate
    ActiveWindow.Refresh
    
    MsgBox "Done! Placed " & plCnt & "/" & totalItems & " on " & pgCnt & " page(s).", _
           vbInformation, "ShoeNester"
    Exit Sub
ErrHandler:
    Application.Optimization = False
    Application.StatusBar = ""
    MsgBox "Error #" & Err.Number & ": " & Err.Description, vbCritical, "ShoeNester"
End Sub


' ============================================================================
' PLACE ONE ITEM
' ============================================================================
Private Function PlaceItem(ByRef srcDoc As Document, _
                            ByRef sr As ShapeRange, _
                            ByVal srcIdx As Long, _
                            ByRef destDoc As Document, _
                            ByRef pg As Page) As Boolean
    PlaceItem = False
    
    ' Copy & paste
    srcDoc.Activate
    sr(srcIdx).Copy
    destDoc.Activate
    pg.Activate
    ActiveLayer.Paste
    
    Dim shp As Shape
    If ActiveSelection.Shapes.Count > 1 Then
        Set shp = ActiveSelection.Group
    ElseIf ActiveSelection.Shapes.Count = 1 Then
        Set shp = ActiveSelection.Shapes(1)
    Else
        Exit Function
    End If
    
    shp.Move -9999, -9999
    
    ' Rotation angles
    Dim ang() As Double
    Dim nA As Long
    If m_DoRotate Then
        nA = 12
        ReDim ang(1 To 12)
        Dim k As Long
        For k = 1 To 12
            ang(k) = (k - 1) * 15
        Next k
    Else
        nA = 1
        ReDim ang(1 To 1)
        ang(1) = 0
    End If
    
    Dim origR As Double
    origR = shp.RotationAngle
    
    Dim bestAI As Long
    Dim bestGX As Long
    Dim bestGY As Long
    Dim bestSc As Double
    Dim found As Boolean
    bestSc = 1E+30
    found = False
    
    Dim ai As Long
    For ai = 1 To nA
        
        ' Apply rotation
        shp.RotationAngle = origR
        If ang(ai) <> 0 Then shp.Rotate ang(ai)
        
        ' ============================================================
        ' RASTERIZE SHAPE ONCE using curve nodes + scanline fill
        ' ============================================================
        Dim shpW As Double
        Dim shpH As Double
        shpW = shp.SizeWidth
        shpH = shp.SizeHeight
        
        Dim hg As Double
        hg = m_Gap / 2
        
        ' Footprint pixel dimensions (shape + gap)
        Dim fpW As Long
        Dim fpH As Long
        fpW = CLng((shpW + m_Gap) / CELL) + 2
        fpH = CLng((shpH + m_Gap) / CELL) + 2
        
        If fpW > m_GW Or fpH > m_GH Then GoTo NxtAng
        If fpW < 1 Or fpH < 1 Then GoTo NxtAng
        
        ' Build footprint by extracting outline points and filling
        Dim fp() As Boolean
        ReDim fp(0 To fpW - 1, 0 To fpH - 1)
        
        Call RasterizeShape(shp, fp, fpW, fpH, hg)
        
        ' Verify footprint has pixels (if not, fall back to filled rect)
        Dim hasPix As Boolean
        hasPix = False
        Dim ci As Long
        Dim cj As Long
        For cj = 0 To fpH - 1
            For ci = 0 To fpW - 1
                If fp(ci, cj) Then
                    hasPix = True
                    GoTo CheckDone
                End If
            Next ci
        Next cj
CheckDone:
        
        ' FALLBACK: if rasterization produced nothing, fill entire bounding box
        ' This ensures shapes ALWAYS get placed even if node extraction fails
        If Not hasPix Then
            For cj = 0 To fpH - 1
                For ci = 0 To fpW - 1
                    fp(ci, cj) = True
                Next ci
            Next cj
        End If
        
        ' ============================================================
        ' SCAN GRID FOR PLACEMENT (using cached footprint)
        ' ============================================================
        Dim gRow As Long
        Dim gCol As Long
        
        For gRow = 0 To m_GH - fpH
            If m_RowFull(gRow) Then GoTo NxtRow
            
            For gCol = 0 To m_GW - fpW
                If m_Grid(gCol, gRow) Then GoTo NxtCol
                
                If Not Collides(fp, fpW, fpH, gCol, gRow) Then
                    Dim score As Double
                    score = CDbl(gRow) * 1000000 + CDbl(gCol)
                    If score < bestSc Then
                        bestSc = score
                        bestAI = ai
                        bestGX = gCol
                        bestGY = gRow
                        found = True
                        GoTo DnAng
                    End If
                End If
NxtCol:
            Next gCol
NxtRow:
        Next gRow
        
DnAng:
NxtAng:
    Next ai
    
    If Not found Then
        shp.Delete
        Exit Function
    End If
    
    ' Apply winning rotation
    shp.RotationAngle = origR
    If ang(bestAI) <> 0 Then shp.Rotate ang(bestAI)
    
    ' Rebuild footprint for stamping
    Dim hg2 As Double
    hg2 = m_Gap / 2
    shpW = shp.SizeWidth
    shpH = shp.SizeHeight
    fpW = CLng((shpW + m_Gap) / CELL) + 2
    fpH = CLng((shpH + m_Gap) / CELL) + 2
    ReDim fp(0 To fpW - 1, 0 To fpH - 1)
    Call RasterizeShape(shp, fp, fpW, fpH, hg2)
    
    ' Check if rasterization worked, fallback to rect if not
    hasPix = False
    For cj = 0 To fpH - 1
        For ci = 0 To fpW - 1
            If fp(ci, cj) Then hasPix = True: GoTo StampReady
        Next ci
    Next cj
StampReady:
    If Not hasPix Then
        For cj = 0 To fpH - 1
            For ci = 0 To fpW - 1
                fp(ci, cj) = True
            Next ci
        Next cj
    End If
    
    ' Move shape to position
    Dim tgtL As Double
    Dim tgtB As Double
    tgtL = m_Margin + CDbl(bestGX) * CELL + hg2
    tgtB = m_Margin + CDbl(bestGY) * CELL + hg2
    shp.Move tgtL - shp.LeftX, tgtB - shp.BottomY
    
    ' Stamp onto master grid
    Call Stamp(fp, fpW, fpH, bestGX, bestGY)
    
    destDoc.ClearSelection
    PlaceItem = True
End Function


' ============================================================================
' RASTERIZE A SHAPE using its curve outline nodes
' Extracts all node X,Y positions, converts to pixel grid,
' then fills the polygon using scanline algorithm
' ============================================================================
Private Sub RasterizeShape(ByRef shp As Shape, ByRef fp() As Boolean, _
                            ByVal fpW As Long, ByVal fpH As Long, ByVal halfGap As Double)
    
    ' Origin = shape's bottom-left minus half gap
    Dim origX As Double
    Dim origY As Double
    origX = shp.LeftX - halfGap
    origY = shp.BottomY - halfGap
    
    ' Collect all node points from the shape
    ' Works with curves, groups, and any shape type
    Dim nodeCount As Long
    nodeCount = 0
    
    ' First pass: count nodes
    Dim nodeX() As Double
    Dim nodeY() As Double
    ReDim nodeX(1 To 5000)
    ReDim nodeY(1 To 5000)
    
    Call CollectNodes(shp, origX, origY, nodeX, nodeY, nodeCount)
    
    ' If no nodes collected, mark entire footprint as filled (bounding box fallback)
    If nodeCount < 3 Then
        Dim fi As Long
        Dim fj As Long
        For fj = 0 To fpH - 1
            For fi = 0 To fpW - 1
                fp(fi, fj) = True
            Next fi
        Next fj
        Exit Sub
    End If
    
    ' Scanline fill: for each row of pixels, find intersections with polygon edges
    ' and fill between pairs
    Dim row As Long
    Dim rowY As Double
    Dim intersections() As Double
    ReDim intersections(1 To 500)
    Dim intCount As Long
    
    For row = 0 To fpH - 1
        rowY = CDbl(row) + 0.5  ' Center of pixel row
        intCount = 0
        
        ' Check each edge of the polygon
        Dim e As Long
        Dim x1 As Double
        Dim y1 As Double
        Dim x2 As Double
        Dim y2 As Double
        Dim nextE As Long
        
        For e = 1 To nodeCount
            If e < nodeCount Then
                nextE = e + 1
            Else
                nextE = 1
            End If
            
            x1 = nodeX(e)
            y1 = nodeY(e)
            x2 = nodeX(nextE)
            y2 = nodeY(nextE)
            
            ' Check if this edge crosses the scanline
            If (y1 <= rowY And y2 > rowY) Or (y2 <= rowY And y1 > rowY) Then
                ' Compute intersection X
                Dim intX As Double
                If Abs(y2 - y1) > 0.001 Then
                    intX = x1 + (rowY - y1) / (y2 - y1) * (x2 - x1)
                Else
                    intX = x1
                End If
                
                intCount = intCount + 1
                If intCount <= 500 Then
                    intersections(intCount) = intX
                End If
            End If
        Next e
        
        ' Sort intersections
        If intCount > 1 Then
            Dim si As Long
            Dim sj As Long
            Dim stmp As Double
            For si = 1 To intCount - 1
                For sj = si + 1 To intCount
                    If intersections(si) > intersections(sj) Then
                        stmp = intersections(si)
                        intersections(si) = intersections(sj)
                        intersections(sj) = stmp
                    End If
                Next sj
            Next si
        End If
        
        ' Fill between pairs of intersections
        Dim pair As Long
        For pair = 1 To intCount - 1 Step 2
            Dim fillStart As Long
            Dim fillEnd As Long
            fillStart = CLng(intersections(pair))
            fillEnd = CLng(intersections(pair + 1))
            
            If fillStart < 0 Then fillStart = 0
            If fillEnd >= fpW Then fillEnd = fpW - 1
            
            Dim col As Long
            For col = fillStart To fillEnd
                If col >= 0 And col < fpW Then
                    fp(col, row) = True
                End If
            Next col
        Next pair
    Next row
    
    ' Also fill a border of 1 pixel around the filled area (gap buffer)
    Dim bpi As Long
    Dim bpj As Long
    Dim tempFP() As Boolean
    ReDim tempFP(0 To fpW - 1, 0 To fpH - 1)
    
    ' Copy original
    For bpj = 0 To fpH - 1
        For bpi = 0 To fpW - 1
            tempFP(bpi, bpj) = fp(bpi, bpj)
        Next bpi
    Next bpj
    
    ' Expand by 1 pixel in all directions
    For bpj = 0 To fpH - 1
        For bpi = 0 To fpW - 1
            If tempFP(bpi, bpj) Then
                ' Mark neighbors
                If bpi > 0 Then fp(bpi - 1, bpj) = True
                If bpi < fpW - 1 Then fp(bpi + 1, bpj) = True
                If bpj > 0 Then fp(bpi, bpj - 1) = True
                If bpj < fpH - 1 Then fp(bpi, bpj + 1) = True
            End If
        Next bpi
    Next bpj
    
End Sub


' ============================================================================
' COLLECT NODE POINTS from a shape (recursive for groups)
' ============================================================================
Private Sub CollectNodes(ByRef shp As Shape, ByVal origX As Double, ByVal origY As Double, _
                          ByRef nodeX() As Double, ByRef nodeY() As Double, ByRef cnt As Long)
    
    On Error Resume Next
    
    ' If it's a group, recurse into children
    If shp.Type = cdrGroupShape Then
        Dim child As Shape
        For Each child In shp.Shapes
            Call CollectNodes(child, origX, origY, nodeX, nodeY, cnt)
        Next child
        Exit Sub
    End If
    
    ' Try to access curve data
    Dim crv As Curve
    Set crv = shp.Curve
    
    If crv Is Nothing Then
        ' Not a curve - use bounding box corners as nodes
        cnt = cnt + 1: If cnt <= 5000 Then nodeX(cnt) = (shp.LeftX - origX) / CELL: nodeY(cnt) = (shp.BottomY - origY) / CELL
        cnt = cnt + 1: If cnt <= 5000 Then nodeX(cnt) = (shp.LeftX + shp.SizeWidth - origX) / CELL: nodeY(cnt) = (shp.BottomY - origY) / CELL
        cnt = cnt + 1: If cnt <= 5000 Then nodeX(cnt) = (shp.LeftX + shp.SizeWidth - origX) / CELL: nodeY(cnt) = (shp.BottomY + shp.SizeHeight - origY) / CELL
        cnt = cnt + 1: If cnt <= 5000 Then nodeX(cnt) = (shp.LeftX - origX) / CELL: nodeY(cnt) = (shp.BottomY + shp.SizeHeight - origY) / CELL
        Exit Sub
    End If
    
    ' Extract nodes from each subpath
    Dim sp As SubPath
    Dim nd As Node
    
    For Each sp In crv.SubPaths
        ' For each subpath, collect nodes as a separate polygon
        ' We'll add them all to the same list for simplicity
        ' (works well for single-outline shapes)
        For Each nd In sp.Nodes
            cnt = cnt + 1
            If cnt <= 5000 Then
                nodeX(cnt) = (nd.PositionX - origX) / CELL
                nodeY(cnt) = (nd.PositionY - origY) / CELL
            End If
        Next nd
    Next sp
    
    On Error GoTo 0
End Sub


' ============================================================================
' COLLISION TEST - Early exit
' ============================================================================
Private Function Collides(ByRef fp() As Boolean, ByVal fw As Long, ByVal fh As Long, _
                           ByVal ox As Long, ByVal oy As Long) As Boolean
    Dim ci As Long
    Dim cj As Long
    Dim mx As Long
    Dim my As Long
    
    For cj = 0 To fh - 1
        my = oy + cj
        If my >= m_GH Then Collides = True: Exit Function
        For ci = 0 To fw - 1
            If fp(ci, cj) Then
                mx = ox + ci
                If mx >= m_GW Then Collides = True: Exit Function
                If m_Grid(mx, my) Then Collides = True: Exit Function
            End If
        Next ci
    Next cj
    
    Collides = False
End Function


' ============================================================================
' STAMP FOOTPRINT + UPDATE ROW CACHE
' ============================================================================
Private Sub Stamp(ByRef fp() As Boolean, ByVal fw As Long, ByVal fh As Long, _
                   ByVal ox As Long, ByVal oy As Long)
    Dim ci As Long
    Dim cj As Long
    Dim mx As Long
    Dim my As Long
    
    For cj = 0 To fh - 1
        my = oy + cj
        If my >= m_GH Then Exit For
        For ci = 0 To fw - 1
            If fp(ci, cj) Then
                mx = ox + ci
                If mx < m_GW Then m_Grid(mx, my) = True
            End If
        Next ci
    Next cj
    
    Call UpdateRowCache(oy, oy + fh - 1)
End Sub

Private Sub UpdateRowCache(ByVal fr As Long, ByVal tr As Long)
    If tr >= m_GH Then tr = m_GH - 1
    If fr < 0 Then fr = 0
    Dim r As Long
    Dim cc As Long
    Dim full As Boolean
    For r = fr To tr
        full = True
        For cc = 0 To m_GW - 1
            If Not m_Grid(cc, r) Then full = False: Exit For
        Next cc
        m_RowFull(r) = full
    Next r
End Sub


' ============================================================================
' GRID INIT
' ============================================================================
Private Sub InitGrid()
    m_GW = CLng(m_UsableW / CELL) + 1
    m_GH = CLng(m_UsableH / CELL) + 1
    If m_GW > 2000 Then m_GW = 2000
    If m_GH > 2000 Then m_GH = 2000
    ReDim m_Grid(0 To m_GW - 1, 0 To m_GH - 1)
    ReDim m_RowFull(0 To m_GH - 1)
    Dim x As Long
    Dim y As Long
    For y = 0 To m_GH - 1
        m_RowFull(y) = False
        For x = 0 To m_GW - 1
            m_Grid(x, y) = False
        Next x
    Next y
End Sub


' ============================================================================
' DRAW MARGIN BOX
' ============================================================================
Private Sub DrawBox(ByRef pg As Page)
    On Error Resume Next
    pg.Activate
    Dim rect As Shape
    Set rect = ActiveLayer.CreateRectangle2(m_Margin, m_Margin, m_UsableW, m_UsableH)
    If Not rect Is Nothing Then
        rect.Outline.Width = 0.1
        Dim clr As New Color
        clr.GrayAssign 60
        rect.Outline.Color = clr
        rect.Fill.ApplyNoFill
        rect.Locked = True
    End If
    On Error GoTo 0
End Sub
